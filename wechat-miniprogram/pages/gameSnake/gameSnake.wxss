/* 贪吃蛇玩法相关样式（棋盘 / 虚拟方向键），配色与全站统一 */

.board {
  position: relative;
  background: #161922;
  padding: 12rpx;
  border-radius: 20rpx;
  border: 4rpx solid #2a3042;
  touch-action: none;
}

.game-canvas {
  display: block;
  width: 640rpx;
  height: 640rpx;
  background: #0a0a15;
  border-radius: 12rpx;
}

/* 移动端虚拟方向键 */
.dpad {
  display: grid;
  grid-template-columns: repeat(3, 96rpx);
  grid-template-rows: repeat(3, 96rpx);
  gap: 12rpx;
  margin: 24rpx auto 0;
  touch-action: none;
}
.dbtn {
  width: 96rpx; height: 96rpx;
  border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  background: #161922;
  color: #6c8cff;
  font-size: 40rpx;
  border: 1rpx solid #2a3042;
}
.dbtn:active { background: #1d3a5f; transform: scale(0.94); }
.dpad .up    { grid-area: 1 / 2; }
.dpad .left  { grid-area: 2 / 1; }
.dpad .right { grid-area: 2 / 3; }
.dpad .down  { grid-area: 3 / 2; }
