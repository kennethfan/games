/* 2048 玩法相关样式（棋盘 / 瓦片 / 动画），配色与 web 版一致 */

.board {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, 150rpx);
  grid-template-rows: repeat(4, 150rpx);
  gap: 20rpx;
  background: #161922;
  padding: 20rpx;
  border-radius: 20rpx;
  border: 4rpx solid #2a3042;
  overflow: hidden;
  touch-action: none;        /* 防止滑动时页面滚动 */
}

/* 底层灰色背景格 */
.cell {
  width: 150rpx;
  height: 150rpx;
  background: #11162a;
  border-radius: 12rpx;
}

.tile-layer {
  position: absolute;
  inset: 20rpx;             /* 与 board padding 对齐 */
  pointer-events: none;
}

/* 瓦片：外层只负责平移定位，过渡产生滑动感 */
.tile {
  position: absolute;
  width: 150rpx;
  height: 150rpx;
  transition: transform 0.11s ease-in-out;
}

/* 内层负责显示与弹出/合并动画，避免与外层 transform 冲突 */
.tile-inner {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

.tile-inner.appear { animation: appear 0.14s ease; }
@keyframes appear {
  from { opacity: 0; transform: scale(0); }
  to   { opacity: 1; transform: scale(1); }
}

.tile-inner.pop { animation: pop 0.18s ease; }
@keyframes pop {
  0%   { transform: scale(0); }
  55%  { transform: scale(1.18); }
  100% { transform: scale(1); }
}
