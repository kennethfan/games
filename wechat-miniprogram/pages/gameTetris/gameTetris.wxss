/* 俄罗斯方块玩法相关样式（棋盘 / 预览 / 触摸控制），配色与全站统一 */

.board {
  position: relative;
  background: #161922;
  padding: 12rpx;
  border-radius: 20rpx;
  border: 4rpx solid #2a3042;
  touch-action: none;
}

.game-canvas {
  display: block;
  width: 460rpx;
  height: 920rpx;
  background: #0a0a15;
  border-radius: 12rpx;
}

.next-canvas {
  display: block;
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto;
  background: #0a0a15;
  border: 1rpx solid #2a3042;
  border-radius: 12rpx;
}

/* 移动端触摸控制按钮 */
.touch-controls {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin: 24rpx auto 0;
  width: 100%;
  max-width: 460rpx;
  touch-action: none;
}
.tc-row { display: flex; gap: 14rpx; }
.tcbtn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 20rpx;
  text-align: center;
  background: #161922;
  color: #6c8cff;
  font-size: 30rpx;
  border: 1rpx solid #2a3042;
}
.tcbtn.wide { flex: 1; }
.tcbtn:active { background: #1d3a5f; transform: scale(0.97); }
