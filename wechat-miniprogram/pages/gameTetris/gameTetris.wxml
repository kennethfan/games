<!-- 俄罗斯方块游戏页 -->
<view class="game-wrap">
  <view class="game-header">
    <view class="back-link" bindtap="goBack">← 返回</view>
    <view class="game-title">俄罗斯方块</view>
    <view class="icon-btn" bindtap="onReset">↻</view>
  </view>

  <view class="game-stats">
    <view class="stat">
      <view class="stat-label">得分</view>
      <view class="stat-value stat-score">{{score}}</view>
    </view>
    <view class="stat">
      <view class="stat-label">等级</view>
      <view class="stat-value">{{level}}</view>
    </view>
    <view class="stat">
      <view class="stat-label">行数</view>
      <view class="stat-value">{{lines}}</view>
    </view>
    <view class="stat">
      <view class="stat-label">最高</view>
      <view class="stat-value stat-best">{{best}}</view>
    </view>
    <view class="stat next-stat">
      <view class="stat-label">下一个</view>
      <canvas type="2d" id="nextCanvas" class="next-canvas"></canvas>
    </view>
  </view>

  <view class="game-stage">
    <view class="board">
      <canvas type="2d" id="gameCanvas" class="game-canvas"
              bindtouchstart="onTouchStart" bindtouchend="onTouchEnd"></canvas>

      <view class="game-overlay" wx:if="{{overlay.show}}">
        <view class="game-overlay-title {{overlay.type}}">{{overlay.title}}</view>
        <view class="game-overlay-sub" wx:if="{{overlay.sub}}">{{overlay.sub}}</view>
        <view class="overlay-btn" bindtap="onOverlayBtn">
          {{overlay.type === 'fail' ? '再来一局' : '继续'}}
        </view>
      </view>

      <!-- 移动端触摸控制按钮 -->
      <view class="touch-controls" wx:if="{{showTouch}}">
        <view class="tc-row">
          <view class="tcbtn" bindtap="onAct" data-act="left">◀</view>
          <view class="tcbtn" bindtap="onAct" data-act="right">▶</view>
        </view>
        <view class="tc-row">
          <view class="tcbtn" bindtap="onAct" data-act="down">▼ 下落</view>
          <view class="tcbtn" bindtap="onAct" data-act="rotate">⟳ 旋转</view>
        </view>
        <view class="tc-row">
          <view class="tcbtn wide" bindtap="onAct" data-act="harddrop">⤓ 硬降</view>
          <view class="tcbtn wide" bindtap="onAct" data-act="pause">⏸ 暂停</view>
        </view>
      </view>
    </view>
  </view>

  <view class="game-toolbar">
    <view class="hint"><text class="b">←→</text> 移动 · <text class="b">↑</text> 旋转 · <text class="b">↓</text> 下落 · <text class="b">空格</text> 硬降</view>
    <view class="toolbar-btns">
      <view class="btn" bindtap="onReset">重新开始</view>
      <button class="share-btn" open-type="share">分享战绩</button>
    </view>
  </view>
</view>
