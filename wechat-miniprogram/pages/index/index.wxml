<!-- 首页：游戏合集入口 -->
<view class="home">
  <view class="hero">
    <view class="hero-title">椒哥休闲游戏</view>
    <view class="hero-sub">原生微信小程序 · 蓝紫风格</view>
  </view>

  <view class="grid">
    <view class="card active" bindtap="go2048">
      <view class="card-emoji">🔢</view>
      <view class="card-name">2048</view>
      <view class="card-desc">滑动合并数字</view>
    </view>
    <view class="card active" bindtap="goSnake">
      <view class="card-emoji">🐍</view>
      <view class="card-name">贪吃蛇</view>
      <view class="card-desc">控制小蛇吃豆</view>
    </view>
    <view class="card active" bindtap="goTetris">
      <view class="card-emoji">🧱</view>
      <view class="card-name">俄罗斯方块</view>
      <view class="card-desc">下落消除方块</view>
    </view>
    <view class="card active" bindtap="goBreakout">
      <view class="card-emoji">🎯</view>
      <view class="card-name">打砖块</view>
      <view class="card-desc">弹球击碎砖块</view>
    </view>
  </view>

  <view class="tip-footer">适度游戏益脑，沉迷游戏伤身。本合集为免费休闲游戏，不含任何内购。</view>

  <!-- 隐私授权弹窗（首次进入） -->
  <view class="privacy-mask" wx:if="{{showPrivacy}}">
    <view class="privacy-box">
      <view class="privacy-title">隐私授权</view>
      <view class="privacy-text">感谢使用《椒哥休闲游戏》。我们重视您的隐私保护，使用前请阅读并同意<text class="privacy-link" bindtap="openPrivacy">《隐私保护指引》</text>。</view>
      <view class="privacy-btns">
        <view class="privacy-btn cancel" bindtap="closePrivacy">暂不使用</view>
        <view class="privacy-btn agree" bindtap="agreePrivacy">同意并继续</view>
      </view>
    </view>
  </view>
</view>
